# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# Env (시크릿 포함)
.env
.env.*
!.env.example

# Local runtime data (Railway volume mirror)
.data/

# Node (web 번들링 도구)
node_modules/
web/node_modules/

# Runtime cache + 디버그 출력 (Playwright 스크린샷, 옛 tarot 디버그 등 빌드 무관)
step_archive/
tarot_*.png
tarot_*.json
inspect_tarot*.js

# web/ 잘못 추적된 Node 잔재 (FastAPI/Python 백엔드라 Node 의존성 0)
web/package.json
web/package-lock.json
web/node_modules/

# 외부 딥리서치 보고서 원본 (프로젝트 루트로 받은 .md) — vault/reports/ 본문화 후 사용
# squeeze-report로 가치 추출 후 vault/reports/<주제>.md 영속화. 원본은 commit X.
/Export.md
/[가-힣]*보고서*.md
/[가-힣]*분석*.md

# 원본 wav/mp4 백업 (다운샘플링 전) — git에 안 올림
*.wav.original
*.mp4.original

# 임시 파일들
C:/temp/

# OS / IDE
.DS_Store
Thumbs.db
.claude/
desktop.ini
.idea/
.vscode/

# Unihan 원본 zip + 추출 txt (빌드 결과 JSON만 commit)
data/unihan/Unihan.zip
data/unihan/*.txt

# 런타임 SQLite DB (사용자 데이터·로그) — Railway volume에서 운영
data/app.db
data/app.db-journal
data/app.db-wal
data/app.db-shm

# Obsidian Vault 설정 (개인 워크스페이스만, 노트는 commit)
vault/.obsidian/workspace*.json
vault/.obsidian/graph.json
vault/.trash/
