# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# Env (시크릿 포함)
.env
.env.*
!.env.example

# Local runtime data (Railway volume mirror)
.data/

# Node (web 번들링 도구)
node_modules/
web/node_modules/

# Runtime cache + 디버그 출력 (Playwright 스크린샷, 옛 tarot 디버그 등 빌드 무관)
step_archive/
tarot_*.png
tarot_*.json
inspect_tarot*.js

# 루트 + web/ 잘못 추적된 Node 잔재 (FastAPI/Python 백엔드라 Node 의존성 0)
# 루트 package.json은 옛 Playwright inspect_tarot.js용이었으며 본 시스템 빌드 무관
/package.json
/package-lock.json
web/package.json
web/package-lock.json
web/node_modules/

# 외부 딥리서치 보고서 원본 (프로젝트 루트로 받은 .md) — vault/reports/ 본문화 후 사용
# squeeze-report로 가치 추출 후 vault/reports/<주제>.md 영속화. 원본은 commit X.
/Export.md
/[가-힣]*보고서*.md
/[가-힣]*분석*.md

# 원본 wav/mp4 백업 (다운샘플링 전) — git에 안 올림
*.wav.original
*.mp4.original

# 임시 파일들
C:/temp/

# 로컬 작업·탐색 흔적 (Playwright 스크린샷, 검증 스크립트 등 — 빌드 무관)
_explore/

# 참고용 이전 작업 폴더 (다른 컴 작업물 백업)
/사주 프로그램/

# OS / IDE
.DS_Store
Thumbs.db
.claude/
desktop.ini
.idea/
.vscode/

# Unihan 원본 zip + 추출 txt (빌드 결과 JSON만 commit)
data/unihan/Unihan.zip
data/unihan/*.txt

# 런타임 SQLite DB (사용자 데이터·로그) — Railway volume에서 운영
data/app.db
data/app.db-journal
data/app.db-wal
data/app.db-shm

# Obsidian Vault — 본 시스템 ADR·reports·references·done·roadmap·templates
# 로컬에는 보존 (Obsidian으로 ADR 35건 + Supplement 7건 등 열람),
# GitHub repo는 빌드+CI/CD 필수만 푸시 (사용자 결정 2026-05-18).
# 본 패턴은 vault/ 전체 자동 무시 — git history는 commit eb14e80 직전까지 영구 보존.
vault/
vault/.trash/
